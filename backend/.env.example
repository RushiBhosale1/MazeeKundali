# ══════════════════════════════════════════════════════════════════
# माझी कुंडली — Backend Environment Variables
# Copy this to .env and fill real values.
# ⚠️  NEVER commit .env to git (it's in .gitignore)
# ══════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
APP_ENV=development           # development | production

# Generate a 32-char random secret:
# python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=c6151183867b7dbc6641ff980d9cbd9eea7cdcc4bb5930f7e39fcdfbab67ba92


# ── Database (Neon PostgreSQL) ────────────────────────────────────
# 1. Go to: https://console.neon.tech
# 2. Create project → "mazeekundali" (region: AWS ap-south-1 Mumbai)
# 3. Click "Connection string" → copy the postgres:// URL
# 4. Paste TWICE below — async uses asyncpg driver, sync uses psycopg2
#
# Neon URL format:
#   postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require
#
# ASYNC URL (FastAPI + SQLAlchemy async) — replace "postgresql://" with "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?ssl=require

# SYNC URL (Alembic migrations) — keep as "postgresql://" but add sslmode
DATABASE_URL_SYNC=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require


# ── Redis ─────────────────────────────────────────────────────────
# For local dev: redis://localhost:6379/0
# For production (Upstash recommended with Neon):
#   https://console.upstash.com → create Redis → copy REST URL
# Use the Redis URL format:  redis://default:[token]@[host]:6379
REDIS_URL=redis://localhost:6379/0


# ── Swiss Ephemeris ───────────────────────────────────────────────
# Relative to backend/ — do not change unless you move the files
EPHE_PATH=./static/ephemeris


# ── Geocoding ─────────────────────────────────────────────────────
# Uses free Nominatim (OpenStreetMap) — set a real contact email/app name
GEOCODING_PROVIDER=nominatim
NOMINATIM_USER_AGENT=mazeekundali/1.0 (contact@yourdomain.in)


# ── Razorpay ──────────────────────────────────────────────────────
# 1. Go to: https://dashboard.razorpay.com/app/keys
# 2. Use rzp_test_* for development, rzp_live_* for production
# 3. NEVER put secret key in frontend code
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Webhook secret:
# 1. Go to: https://dashboard.razorpay.com/app/webhooks
# 2. Create webhook → URL: https://yourapi.com/api/v1/webhooks/razorpay
# 3. Events: payment.captured (ONLY this one)
# 4. Copy "Webhook Secret" → paste here
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX


# ── Cloudinary (PDF + image storage) ─────────────────────────────
# 1. Go to: https://cloudinary.com → sign up (free tier: 25GB)
# 2. Dashboard → Settings → API Keys → Copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
CLOUDINARY_FOLDER=mazeekundali       # all uploads go inside this folder


# ── Sentry (Error Tracking) ───────────────────────────────────────
# Leave empty in dev — errors will show in terminal logs
# For production: https://sentry.io → create project → copy DSN
SENTRY_DSN=


# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_GEOCODE=30/minute
RATE_LIMIT_KUNDALI_CREATE=5/10minutes
